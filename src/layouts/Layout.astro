---
import '../styles/global.css';
import { ArrowDown, ArrowUpRight } from 'lucide-astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bohdan Doshchak — Lead UI/UX Designer',
  description = 'Lead UI/UX Designer & Design Manager. 20+ years building product design systems for SaaS, healthcare, and enterprise platforms.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>

  <body>
    <!-- ===== NAV ===== -->
    <nav class="nav" aria-label="Main navigation">
      <div class="nav-inner container">
        <a href="/" class="nav-logo" aria-label="Bohdan Doshchak — home">
          <!-- BD mark only -->
          <svg width="24" height="18" viewBox="0 0 32 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M9.71582 0C12.6206 0 14.8158 0.518979 16.3027 1.55469C16.6754 1.32112 17.0777 1.11166 17.5088 0.925781C18.94 0.308712 20.5858 4.36665e-06 22.4463 0H31.5703C31.6895 0 31.7972 0.0454516 31.8926 0.136719C31.9641 0.205231 31.9999 0.296986 32 0.411133V23.5889C31.9999 23.703 31.9641 23.8061 31.8926 23.8975C31.7972 23.9659 31.6895 24 31.5703 24H22.4463C20.5858 24 18.94 23.6913 17.5088 23.0742C17.0813 22.8899 16.6826 22.6815 16.3125 22.4502C14.6841 23.4816 12.5823 24 10.0039 24H0.431641C0.311947 24 0.2042 23.9658 0.108398 23.8975C0.0364909 23.8061 6.20243e-05 23.703 0 23.5889V0.411133C6.22124e-05 0.296986 0.036491 0.205231 0.108398 0.136719C0.204199 0.0456173 0.311947 4.50397e-05 0.431641 0H9.71582ZM22.2314 4.86816C21.2535 4.86821 20.4664 5.20047 19.8701 5.86328C19.25 6.50326 18.9395 7.37171 18.9395 8.46875V15.5312C18.9633 16.6284 19.2738 17.509 19.8701 18.1719C20.4664 18.8117 21.2422 19.1318 22.1963 19.1318H25.8818C26.0008 19.1317 26.0605 19.0741 26.0605 18.96V5.04004C26.0605 4.92591 26.0008 4.86832 25.8818 4.86816H22.2314ZM6.15332 14.1943C6.0336 14.1944 5.9738 14.2513 5.97363 14.3652V18.9258C5.97366 19.04 6.03345 19.0967 6.15332 19.0967H10.0039C10.9631 19.0967 11.7067 18.8916 12.2344 18.4805C12.6948 18.1016 12.9539 17.583 13.0127 16.9258C13.005 16.7826 13 16.6377 13 16.4912V16.2471C12.9253 15.6543 12.6721 15.1869 12.2344 14.8457C11.7306 14.4116 10.9873 14.1944 10.0039 14.1943H6.15332ZM6.15332 4.86816C6.03343 4.86819 5.97363 4.92578 5.97363 5.04004V9.36035C5.97376 9.47438 6.03355 9.53122 6.15332 9.53125H9.71582C10.6994 9.53125 11.4556 9.33681 11.9834 8.94824C12.5109 8.53686 12.7744 7.96556 12.7744 7.23438C12.7744 6.48014 12.5111 5.89678 11.9834 5.48535C11.4556 5.07392 10.6994 4.86816 9.71582 4.86816H6.15332Z" fill="currentColor"/>
          </svg>
        </a>

        <ul class="nav-links" role="list">
          <li><a href="/work" class="nav-link">Work</a></li>
          <li><a href="/about" class="nav-link">About</a></li>
          <li><a href="/#contact" class="nav-link">Contact</a></li>
        </ul>
      </div>
    </nav>

    <!-- ===== MAIN ===== -->
    <main id="main">
      <slot />
    </main>

    <!-- ===== CURSOR ===== -->
    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>

    <!-- ===== FOOTER ===== -->
    <footer class="footer">
      <div class="footer-inner container">
        <span class="footer-copy">© 2026 Bohdan Doshchak</span>
        <nav class="footer-links" aria-label="Footer links">
          <a href="https://www.linkedin.com/in/bdoshchak/" target="_blank" rel="noopener" class="footer-link">LinkedIn <ArrowUpRight size={12} class="inline-icon" /></a>
          <a href="mailto:doschak@gmail.com" class="footer-link">Email</a>
          <a href="/cv.pdf" class="footer-link">CV</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<script is:inline>
(function () {
  // Only on pointer-fine (mouse) devices
  if (!window.matchMedia('(pointer: fine)').matches) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const dot  = document.querySelector('.cursor-dot');
  const ring = document.querySelector('.cursor-ring');
  if (!dot || !ring) return;

  // Hide native cursor
  document.documentElement.style.cursor = 'none';

  let mx = -200, my = -200; // mouse target
  let rx = -200, ry = -200; // ring interpolated position

  window.addEventListener('mousemove', (e) => {
    mx = e.clientX;
    my = e.clientY;
  });

  window.addEventListener('mouseleave', () => {
    dot.classList.add('is-hidden');
    ring.classList.add('is-hidden');
  });

  window.addEventListener('mouseenter', () => {
    dot.classList.remove('is-hidden');
    ring.classList.remove('is-hidden');
  });

  // Expand ring on interactive elements
  document.addEventListener('mouseover', (e) => {
    if (e.target.closest('a, button, [role="button"]')) {
      ring.classList.add('is-hover');
    } else {
      ring.classList.remove('is-hover');
    }
  });

  function lerp(a, b, t) { return a + (b - a) * t; }

  function tick() {
    // Dot: snaps instantly
    dot.style.transform =
      `translate3d(calc(${mx}px - 50%), calc(${my}px - 50%), 0)`;

    // Ring: lags behind with lerp
    rx = lerp(rx, mx, 0.10);
    ry = lerp(ry, my, 0.10);
    ring.style.transform =
      `translate3d(calc(${rx}px - 50%), calc(${ry}px - 50%), 0)`;

    requestAnimationFrame(tick);
  }

  tick();
})();
</script>

<script is:inline>
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  var sections = document.querySelectorAll('main section:not(.hero)');

  sections.forEach(function (s) {
    s.classList.add('scroll-reveal');
  });

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08 });

  sections.forEach(function (s) { io.observe(s); });
})();
</script>

<style>
  /* ===== SCROLL REVEAL ===== */
  @media (prefers-reduced-motion: no-preference) {
    .scroll-reveal {
      opacity: 0;
      transform: translateY(36px);
      transition:
        opacity  640ms cubic-bezier(0, 0, 0.2, 1),
        transform 640ms cubic-bezier(0, 0, 0.2, 1);
    }
    .scroll-reveal.is-visible {
      opacity: 1;
      transform: none;
    }
  }

  /* ===== NAV ===== */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-black);
    border-bottom: 1px solid oklch(20% 0 0);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .nav-logo {
    color: var(--color-white);
    display: flex;
    align-items: center;
    transition: opacity var(--dur-fast) var(--ease);
  }

  .nav-logo:hover { opacity: 0.7; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--sp-8);
  }

  .nav-link {
    font-family: var(--font-display);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-label);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-white);
    opacity: 0.6;
    transition: opacity var(--dur-fast) var(--ease);
  }

  .nav-link:hover { opacity: 1; }

  @media (max-width: 640px) {
    .nav-links { gap: var(--sp-4); }
    .nav-link { letter-spacing: var(--ls-wide); }
  }

  /* ===== FOOTER ===== */
  .footer {
    background: var(--color-black);
    border-top: 1px solid oklch(20% 0 0);
    padding: var(--sp-8) 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  .footer-copy {
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    color: var(--color-grey-400);
  }

  .footer-links {
    display: flex;
    gap: var(--sp-6);
  }

  .footer-link {
    font-family: var(--font-display);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-label);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--color-grey-400);
    transition: color var(--dur-fast) var(--ease);
  }

  .footer-link:hover { color: var(--color-white); }

  /* ===== CUSTOM CURSOR ===== */
  @media (pointer: fine) {
    .cursor-dot,
    .cursor-ring {
      position: fixed;
      top: 0;
      left: 0;
      pointer-events: none;
      z-index: 9999;
      will-change: transform;
      mix-blend-mode: difference;
    }

    .cursor-dot {
      width: 6px;
      height: 6px;
      background: #fff;
      border-radius: 50%;
    }

    .cursor-ring {
      width: 36px;
      height: 36px;
      border: 1.5px solid rgba(255, 255, 255, 0.85);
      border-radius: 50%;
      transition:
        width  300ms cubic-bezier(0.4, 0, 0.2, 1),
        height 300ms cubic-bezier(0.4, 0, 0.2, 1),
        opacity 200ms;
    }

    .cursor-ring.is-hover {
      width: 60px;
      height: 60px;
    }

    .cursor-dot.is-hidden  { opacity: 0; }
    .cursor-ring.is-hidden { opacity: 0; }
  }

  @media (pointer: coarse), (prefers-reduced-motion: reduce) {
    .cursor-dot,
    .cursor-ring { display: none; }
  }
</style>
