---
import Layout from '../layouts/Layout.astro';
import { ArrowLeft, ArrowRight, ArrowUpRight } from 'lucide-astro';

const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const periods = [
  {
    size: 'hero',
    period: '2020 – 2026',
    role: 'Senior UI/UX Designer · Design Community Lead',
    company: 'Master of Code Global',
    focus: 'Leadership · Enterprise SaaS · Design Systems · Mentorship',
    description: 'Led design across concurrent enterprise engagements – LivePerson, healthcare SaaS, luxury retail, political platforms. Maintained three coexisting design systems while keeping four engineering teams supplied with production-ready specs. Promoted to Design Community Lead; scaled the internal design practice from the ground up.',
    bullets: [
      'Built and facilitated biweekly design community meetings, critique sessions, and skill-share workshops',
      'Defined the team\'s Skill Matrix and career framework; ran 1:1s and growth planning with junior and mid-level designers',
      'Introduced AI-augmented prototyping workflows – cutting proof-of-concept time from weeks to hours',
      'Drove WCAG 2.0 AA adoption across all active client products',
    ],
  },
  {
    size: 'standard',
    period: '2015 – 2020',
    role: 'UI/UX Designer',
    company: 'Master of Code Global',
    focus: 'Complexity & Systems · B2B CRM · Mobile Apps',
    description: 'Took on progressively larger product scopes – multi-surface SaaS platforms, B2B CRM tools, and cross-platform mobile apps for enterprise clients. Shifted from screen-level execution to system-level thinking: information architecture, component design, and cross-team handoff at scale. Led migration from Photoshop to Figma for a major client engagement.',
  },
  {
    size: 'compact',
    period: '2007 – 2015',
    role: 'Web Designer',
    company: 'Master of Code Global',
    focus: 'Web Evolution · Early Mobile',
    description: 'Joined as a generalist web designer; grew through the transition from static web to responsive design and first-generation mobile experiences. Built the foundation in visual systems, typography, and cross-browser implementation that informs everything since.',
  },
];

const values = [
  {
    label: 'Systems first',
    body: 'Design that doesn\'t scale is just decoration. I build for the second screen, the third product, the team that inherits the work.',
  },
  {
    label: 'Engineering mindset',
    body: 'I treat technical constraints as information, not obstacles. My understanding of how digital products are built allows me to speak the language of implementation and design with execution in mind.',
  },
  {
    label: 'Craft at every scale',
    body: 'Whether it\'s a 1,000-icon library or a single empty state – attention to detail is not optional. It compounds.',
  },
];
---

<Layout title="About – Bohdan Doshchak" description="20+ years of product design experience. UI/UX Designer & Design Manager specializing in design systems, enterprise SaaS, and multi-team design leadership.">
  <!-- ================================================
       PAGE HEADER
       ================================================ -->
  <section class="page-header" aria-label="About introduction">
    <div class="container">
      <div class="page-header-content">
      <div class="page-header-grid">
        <div class="page-header-text">
          <a href={b + '/'} class="page-back label">
            <ArrowLeft size={13} class="inline-icon" /> Home
          </a>
          <h1 class="page-title">I design systems,<br />not just screens.</h1>
          <p class="page-intro">
            UI/UX Designer & Design Manager with 20+ years across agency
            and in-house product teams. Specialise in design systems, multi-team
            design leadership, and shipping complex SaaS products at scale.
          </p>
        </div>
        <div class="page-header-photo">
          <div class="photo-wrap">
            <img
              src={b + '/me.png'}
              alt="Bohdan Doshchak"
              class="photo"
              width="480"
              height="600"
              loading="eager"
            />
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       BIO
       ================================================ -->
  <section class="bio-section" aria-label="Biography">
    <div class="container">
      <header class="section-header">
        <span class="section-counter label" aria-hidden="true">[01]</span>
        <h2 class="section-title">Background</h2>
      </header>
      <div class="bio-body">
          <p class="bio-paragraph bio-lead">
            20 years teaches you what actually works. Redesigns stick when the
            team owns them from the start. Component libraries survive when
            governance is built in, not bolted on later. Handoffs land when
            specs are written for the engineer, not the design review. I've been
            through enough cycles to know the difference – and I build that way
            from day one.
          </p>
          <p class="bio-paragraph">
            I started freelancing in 2001 – websites for local businesses,
            small NGOs, anything that needed a screen. By 2007 that became a
            full-time role at Master of Code Global, a service agency with a
            genuinely wide brief. Over the following 19 years I designed for
            funded startups, healthcare platforms, luxury retail brands, sports
            organisations, and political campaigns. That breadth is deliberate.
            Working outside a single vertical forces rigour: you can't rely on
            domain familiarity to fill the gaps in your thinking.
          </p>
          <p class="bio-paragraph">
            The most complex engagement was LivePerson – a conversational AI
            platform – where, as a contractor via MOCG, I was embedded across
            four engineering teams simultaneously. Three parallel design systems.
            A product undergoing architectural migration. The job was
            coordination as much as creation – keeping quality consistent while
            keeping teams moving. An engineering background made the translation
            natural. I don't just hand off to developers; I work with them.
          </p>
          <p class="bio-paragraph">
            Based in Cherkasy, Ukraine. Available for remote-first roles and
            select consulting engagements.
          </p>
        </div>
    </div>
  </section>

  <!-- ================================================
       VALUES
       ================================================ -->
  <section class="values-section" aria-label="Professional values">
    <div class="container">
      <header class="section-header">
        <span class="section-counter label" aria-hidden="true">[02]</span>
        <h2 class="section-title">How I Work</h2>
      </header>
      <ul class="values-grid" role="list">
        {values.map((v) => (
          <li class="value-item">
            <p class="value-label label">{v.label}</p>
            <p class="value-body">{v.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ================================================
       EXPERIENCE
       ================================================ -->
  <section class="exp-section" aria-label="Work experience">
    <div class="container">
      <header class="section-header">
        <span class="section-counter label" aria-hidden="true">[03]</span>
        <h2 class="section-title">Experience</h2>
      </header>

      <p class="exp-company-label label">Master of Code Global</p>

      <ol class="exp-timeline" role="list">
        {periods.map((p) => (
          <li class={`exp-period exp-period--${p.size}`}>
            <div class="exp-period-meta">
              <span class="exp-period-range label">{p.period}</span>
              <span class="exp-period-focus">{p.focus}</span>
            </div>
            <div class="exp-period-body">
              <h3 class="exp-role-title">{p.role}</h3>
              <p class="exp-description">{p.description}</p>
              {p.bullets && (
                <ul class="exp-bullets" role="list">
                  {p.bullets.map((b) => (
                    <li class="exp-bullet">{b}</li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))}
      </ol>

      <p class="exp-company-label label" style="margin-top: var(--sp-16);">Freelance</p>
      <ol class="exp-timeline exp-timeline--secondary" role="list">
        <li class="exp-period exp-period--compact">
          <div class="exp-period-meta">
            <span class="exp-period-range label">2001 – present</span>
            <span class="exp-period-focus">Parallel to agency work</span>
          </div>
          <div class="exp-period-body">
            <h3 class="exp-role-title">Web Designer / UI Designer</h3>
            <p class="exp-description">Side projects and independent client work running in parallel with agency employment – web design, identity, and UI for small businesses and non-commercial organisations.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ================================================
       CONTACT CTA
       ================================================ -->
  <section class="contact-section" aria-label="Contact" style={`background-image: url('${b}/cutting_mat_bg.png')`}>
    <div class="container">
      <div class="contact-eyebrow">
        <span class="contact-counter label">[04]</span>
        <span class="contact-label label">Let's talk</span>
      </div>
      <h2 class="contact-heading">
        Ready when<br />you are.
      </h2>
      <div class="contact-links">
        <a href="mailto:doschak@gmail.com" class="contact-btn">
          Get in touch
        </a>
        <a href={b + '/cv.pdf'} target="_blank" rel="noopener" class="contact-btn contact-btn--secondary">
          View CV
        </a>
        <a href="https://www.linkedin.com/in/bdoshchak/" target="_blank" rel="noopener" class="contact-linkedin label">
          LinkedIn <ArrowUpRight size={13} class="inline-icon" />
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { revealEach, revealGroup } from '../scripts/reveal';

  function init() {
    revealEach('.section-header');
    revealEach('.photo-wrap', 0.1);
    revealGroup('.bio-body', '.bio-paragraph', 0.1);
    revealGroup('.values-grid', '.value-item', 0.1);
    revealGroup('.exp-timeline', '.exp-period', 0.1);
  }

  document.addEventListener('astro:page-load', init);
</script>

<style>
  /* ================================================
     PAGE HEADER
     ================================================ */
  .page-header {
    background: var(--color-black);
    padding-top: calc(60px + var(--sp-16));
    padding-bottom: var(--sp-24);
  }

  .page-header-content {
    /* wrapper for z-index stacking if needed */
  }

  .page-header-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--sp-16);
    align-items: end;
  }

  .page-back {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--color-grey-400);
    margin-bottom: var(--sp-12);
    transition: color var(--dur-fast) var(--ease);
  }

  .page-back:hover { color: var(--color-white); }

  .page-title {
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: var(--fs-display);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-tight);
    color: var(--color-white);
    margin-bottom: var(--sp-8);
  }

  .page-intro {
    font-family: var(--font-body);
    font-size: var(--fs-body-lg);
    color: var(--color-grey-450);
    line-height: var(--lh-loose);
    max-width: 52ch;
  }

  .photo-wrap {
    position: relative;
    height: 100%;
    display: flex;
    align-items: flex-end;
  }

  .photo {
    width: 115%;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
    filter: grayscale(30%) contrast(1.05);
  }

  @media (max-width: 768px) {
    .page-header-grid {
      grid-template-columns: 1fr;
    }
    .page-header-photo {
      max-width: 260px;
    }
  }

  /* ================================================
     SECTION SHARED
     ================================================ */
  .section-header {
    position: relative;
    margin-bottom: var(--sp-12);
    padding-top: var(--sp-24);
  }

  .section-counter {
    position: absolute;
    top: var(--sp-24);
    right: 100%;
    padding-right: var(--sp-4);
    color: var(--accent-text);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .section-counter {
      position: static;
      display: block;
      margin-bottom: var(--sp-2);
    }
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: var(--fs-h1);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-tight);
    color: var(--text-primary);
  }

  /* ================================================
     BIO
     ================================================ */
  .bio-section {
    background: var(--bg-primary);
    padding-top: 0;
    padding-bottom: var(--sp-24);
  }

  .bio-body {
    max-width: 68ch;
  }

  .bio-paragraph {
    font-family: var(--font-body);
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    line-height: var(--lh-loose);
    margin-bottom: var(--sp-6);
  }

  .bio-paragraph:last-child { margin-bottom: 0; }

  .bio-lead {
    color: var(--text-primary);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
  }


  /* ================================================
     VALUES
     ================================================ */
  .values-section {
    background: var(--bg-secondary);
    padding-bottom: var(--sp-24);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .value-item {
    padding: var(--sp-8) var(--sp-8) var(--sp-8) 0;
  }

  .value-item + .value-item {
    padding-left: var(--sp-8);
    border-left: 1px solid var(--border);
  }

  .value-label {
    color: var(--accent-text);
    margin-bottom: var(--sp-3);
  }

  .value-body {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: var(--lh-loose);
  }

  @media (max-width: 768px) {
    .values-grid { grid-template-columns: 1fr; }
    .value-item + .value-item {
      padding-left: 0;
      border-left: none;
    }
  }

  /* ================================================
     EXPERIENCE
     ================================================ */
  .exp-section {
    background: var(--bg-primary);
    padding-bottom: var(--sp-24);
  }

  .exp-company-label {
    color: var(--text-muted);
    margin-bottom: var(--sp-8);
    display: block;
  }

  /* Timeline */
  .exp-timeline {
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border);
    margin-bottom: var(--sp-16);
  }

  .exp-period {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: var(--sp-8);
    padding: var(--sp-8) 0 var(--sp-8) var(--sp-8);
    position: relative;
  }

  /* dot on the timeline */
  .exp-period::before {
    content: '';
    position: absolute;
    left: -4px;
    top: calc(var(--sp-8) + 0.4em);
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--border-strong);
  }

  .exp-period--hero::before {
    background: var(--accent-text);
    width: 9px;
    height: 9px;
    left: -5px;
  }

  .exp-period + .exp-period {
    border-top: 1px solid var(--border);
  }

  /* Meta column */
  .exp-period-meta {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding-top: 2px;
  }

  .exp-period-range {
    color: var(--accent-text);
  }

  .exp-period-focus {
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    color: var(--text-muted);
    line-height: var(--lh-snug);
  }

  /* Body column */
  .exp-period-body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  /* Hero period – larger title */
  .exp-period--hero .exp-role-title {
    font-size: var(--fs-h1);
    letter-spacing: var(--ls-tight);
  }

  .exp-role-title {
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: var(--fs-h2);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
    color: var(--text-primary);
  }

  .exp-description {
    font-family: var(--font-body);
    color: var(--text-secondary);
    line-height: var(--lh-loose);
    max-width: 68ch;
  }

  /* Hero: regular body size */
  .exp-period--hero .exp-description {
    font-size: var(--fs-body-lg);
  }

  /* Standard: regular body */
  .exp-period--standard .exp-description {
    font-size: var(--fs-body);
  }

  /* Compact: smaller, muted */
  .exp-period--compact .exp-role-title {
    font-size: var(--fs-body-lg);
    font-weight: var(--fw-extrabold);
  }

  .exp-period--compact .exp-description {
    font-size: var(--fs-caption);
    color: var(--text-muted);
  }

  /* Bullets */
  .exp-bullets {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-top: var(--sp-1);
    padding-left: var(--sp-4);
    border-left: 2px solid var(--border);
  }

  .exp-bullet {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }

  /* Secondary (freelance) timeline – same border as primary */
  .exp-timeline--secondary .exp-period::before {
    background: var(--border-strong);
  }

  @media (max-width: 640px) {
    .exp-period {
      grid-template-columns: 1fr;
      gap: var(--sp-3);
    }
  }

  /* ================================================
     CONTACT
     ================================================ */
  .contact-section {
    background-size: cover;
    background-position: center;
    padding-top: var(--sp-24);
    padding-bottom: var(--sp-24);
  }

  .contact-section > :global(.container) {
    position: relative;
    z-index: 1;
  }

  .contact-eyebrow {
    position: relative;
    margin-bottom: var(--sp-6);
  }

  .contact-counter {
    position: absolute;
    right: 100%;
    top: 0;
    padding-right: var(--sp-4);
    white-space: nowrap;
    color: var(--color-grey-400);
  }

  .contact-label {
    color: var(--color-grey-400);
  }

  @media (max-width: 640px) {
    .contact-counter {
      position: static;
      display: inline;
      padding-right: var(--sp-2);
    }
  }

  .contact-heading {
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: var(--fs-hero);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-tight);
    color: var(--color-white);
    margin-bottom: var(--sp-12);
  }

  .contact-links {
    display: flex;
    align-items: center;
    gap: var(--sp-8);
    flex-wrap: wrap;
  }

  .contact-btn {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-label);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-white);
    background: var(--color-blue);
    padding: var(--sp-4) var(--sp-8);
    transition: background var(--dur-fast) var(--ease),
                color var(--dur-fast) var(--ease);
  }

  .contact-btn:hover {
    background: var(--color-blue-dim);
    color: var(--color-white);
  }

  .contact-btn--secondary {
    background: transparent;
    color: var(--color-white);
    border: 1px solid oklch(45% 0 0);
  }

  .contact-btn--secondary:hover {
    background: oklch(18% 0 0);
    border-color: oklch(60% 0 0);
  }

  .contact-linkedin {
    color: var(--color-grey-400);
    transition: color var(--dur-fast) var(--ease);
  }

  .contact-linkedin:hover { color: var(--color-white); }
</style>
