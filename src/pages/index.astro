  .hero-cta {
    will-change: transform;
  }

</style>

<script is:inline>
(function () {
  if (!window.matchMedia('(pointer: fine)').matches) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  /* ── HERO PARALLAX ─────────────────────────────── */
  const hero = document.querySelector('.hero');
  if (hero) {
    const layers = [
      { el: document.querySelector('.hero-label'),     x:  12, y:  6  },
      { el: document.querySelector('.hero-name'),      x: -28, y: -14 },
      { el: document.querySelector('.hero-statement'), x:  18, y:  9  },
      { el: document.querySelector('.hero-cta'),       x:  10, y:  5  },
    ];

    let tx = 0, ty = 0; // target (normalised -1…1)
    let cx = 0, cy = 0; // current (lerped)

    hero.addEventListener('mousemove', (e) => {
      const r = hero.getBoundingClientRect();
      tx = (e.clientX - r.left  - r.width  / 2) / (r.width  / 2);
      ty = (e.clientY - r.top   - r.height / 2) / (r.height / 2);
    });

    hero.addEventListener('mouseleave', () => { tx = 0; ty = 0; });

    function lerp(a, b, t) { return a + (b - a) * t; }

    (function tickParallax() {
      cx = lerp(cx, tx, 0.055);
      cy = lerp(cy, ty, 0.055);
      layers.forEach(({ el, x, y }) => {
        if (el) el.style.transform =
          `translate3d(${cx * x}px, ${cy * y}px, 0)`;
      });
      requestAnimationFrame(tickParallax);
    })();
  }

})();
</script>
